{
  "name": "@territory-wars/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/local.js",
  "types": "./dist/app.d.ts",
  "scripts": {
    "prebuild": "npm --workspace @territory-wars/game-engine run build",
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/local.js",
    "pretypecheck": "npm --workspace @territory-wars/game-engine run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@territory-wars/game-engine": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "vitest": "^4.1.9"
  }
}
